    "@babel/preset-typescript": "^7.23.0",
    "@google/clasp": "^2.4.2",
    "@types/google-apps-script": "^1.0.73",
    "@types/react": "^18.2.0",
    "@types/react-dom": "^18.2.0",
    "babel-loader": "^9.1.3",
    "css-loader": "^6.8.1",
    "gas-webpack-plugin": "^2.0.0",
    "html-webpack-plugin": "^5.5.3",
    "style-loader": "^3.3.3",
    "ts-loader": "^9.5.0",
